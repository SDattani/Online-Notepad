    {
      "name": "Team Roles",
      "item": [
        {
          "name": "Create Role (No Parent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager\",\n  \"permissions\": [\n    \"note:create\",\n    \"note:edit\",\n    \"note:view\",\n    \"note:share\",\n    \"note:delete\",\n    \"role:assign\",\n    \"role:delete\",\n    \"member:invite\",\n    \"member:remove\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/teams/1/roles", "host": ["{{baseUrl}}"], "path": ["teams", "1", "roles"] }
          }
        },
        {
          "name": "Create Role (With Parent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Developer\",\n  \"parentRoleName\": \"Manager\",\n  \"permissions\": [\n    \"note:create\",\n    \"note:edit\",\n    \"note:view\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/teams/1/roles", "host": ["{{baseUrl}}"], "path": ["teams", "1", "roles"] }
          }
        },
        {
          "name": "Create Role (Intern under Developer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Intern\",\n  \"parentRoleName\": \"Developer\",\n  \"permissions\": [\n    \"note:view\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/teams/1/roles", "host": ["{{baseUrl}}"], "path": ["teams", "1", "roles"] }
          }
        },
        {
          "name": "Get All Roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/teams/1/roles", "host": ["{{baseUrl}}"], "path": ["teams", "1", "roles"] }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/teams/1/roles/Intern", "host": ["{{baseUrl}}"], "path": ["teams", "1", "roles", "Intern"] }
          }
        }
